\section{Introduction}

% --- Slide 3: Research Problem (Inheriting Colors) ---
\begin{frame}{Research Problem}
    \begin{itemize}
        \item \textbf{Global Challenge:} Timing is critical in pandemic response.
        \item \textbf{Individual Decision-making:} Why do people delay vaccination?
        \item \textbf{Current Gap:} Limited understanding of time preferences in health behavior models.
    \end{itemize}
    
    \begin{block}{Core Conflict}
        Balancing immediate costs (side effects, time) vs. future benefits (protection, social mobility).
    \end{block}
\end{frame}

\section{Research Questions}

% --- Slide 4: Research Questions ---
\begin{frame}{Research Questions}
    \begin{enumerate}
        \item How does \textbf{time delay} affect the perceived utility of different vaccines?
        \item Does \textbf{intertemporal discounting} vary across socio-demographic groups?
        \item Can specific \textbf{policy incentives} nudge early vaccination?
    \end{enumerate}
\end{frame}

